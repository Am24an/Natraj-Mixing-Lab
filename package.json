{
  "name": "natraj-passport-studio",
  "private": true,
  "version": "1.0.0",
  "description": "Natraj Mixing Lab – Browser-Based Passport Photo Studio",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "graph:update": "code-review-graph update",
    "graph:watch": "code-review-graph watch"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@tensorflow/tfjs": "^4.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-image-crop": "^11.1.2",
    "tailwind-merge": "^3.3.0",
    "upscaler": "^1.0.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.1.10",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.10",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.34.0",
    "vite": "^8.1.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "protobufjs@7.6.5": true
  }
}
